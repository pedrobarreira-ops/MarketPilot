# Server
PORT=3000
NODE_ENV=development
# Coolify deployment: set NODE_ENV=production in Coolify's env UI

# Redis (BullMQ backend)
REDIS_URL=redis://localhost:6379
# In Docker: redis://redis:6379  (use the container service name as hostname)

# Database
SQLITE_PATH=./marketpilot.db

# Resend (transactional email) — Optional: emails are disabled if unset or left as the placeholder below
RESEND_API_KEY=re_your_key_here

# App
APP_BASE_URL=https://reports.yourdomain.com
# Set to your public Coolify domain, e.g. https://reports.example.com
WORTEN_BASE_URL=https://marketplace.worten.pt

# Logging — NEVER use 'debug' in production (may include request details)
LOG_LEVEL=info
# Coolify deployment: set LOG_LEVEL=info — never use 'debug' in production
